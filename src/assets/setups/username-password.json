{
  "title": "Username & Password",
  "order": 2,
  "blocks": [
    {
      "type": "p",
      "content": "DSP supports the Username & Password authentication flow."
    },
    {
      "type": "p",
      "content": "This method uses:"
    },
    {
      "type": "ul",
      "children": [
        { "type": "p", "content": "<strong>Username</strong>" },
        { "type": "p", "content": "<strong>Password + Security Token</strong>" }
      ]
    },
    {
      "type": "p",
      "content": "Authentication is handled securely through <strong>Salesforce's Named Credential</strong> feature, which stores and manages the credentials safely within the platform."
    },
    {
      "type": "p",
      "content": "Follow the steps below to configure Username & Password authentication."
    },
    {
      "type": "h2",
      "content": "1. Create Named Credential (DSP installed Org)",
      "children": [
        {
          "type": "image",
          "content": "image/connection/username-password/named-credential-new-legacy.png",
          "alt": "Create Named Credential"
        },
        {
          "type": "image",
          "content": "image/connection/username-password/named-credential-setup.png",
          "alt": "Named Credential Configurations",
          "caption": [
            "Username: Enter the main username of the connected organization.",
            "Enter the user's password combined with the security token. If a security token is not applicable, omit it."
          ]
        }
      ]
    },
    {
      "type": "h2",
      "content": "2. Create DSP Connection (DSP installed Org)",
      "children": [
        {
          "type": "image",
          "content": "image/connection/username-password/create-connection.png",
          "alt": "Create Connection"
        }
      ]
    },
    {
      "type": "h2",
      "content": "3. Test Connection",
      "children": [
        {
          "type": "image",
          "content": "image/connection/username-password/test-connection.png",
          "alt": "Test Connection"
        }
      ]
    }
  ]
}
